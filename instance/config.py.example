"""
instance/config.py — Deployment-specific configuration.

Copy this file to instance/config.py and fill in real values.
The actual config.py is git-ignored and never committed.
"""

import os

# --- Flask / SQLAlchemy -------------------------------------------------------
DEBUG = os.environ.get("FLASK_DEBUG", "false").lower() == "true"
SQLALCHEMY_ECHO = False
SQLALCHEMY_TRACK_MODIFICATIONS = False
SQLALCHEMY_DATABASE_URI = "sqlite:///../database_bcrypt.db"

# Required — generate with: python -c "import secrets; print(secrets.token_urlsafe(20))"
