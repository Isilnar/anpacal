# =============================================================================
# anpacal — Environment variables template
# =============================================================================
# Copia este archivo como .env y rellena los valores reales.
# El archivo .env NUNCA se commitea (está en .gitignore).
#
# Generar SECRET_KEY:
#   python -c "import secrets; print(secrets.token_urlsafe(20))"
#
# Generar FERNET_KEY:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# =============================================================================

# --- Flask (obligatorio) -----------------------------------------------------
SECRET_KEY=
FERNET_KEY=

# --- Mail (opcional — solo si usás envío de contraseñas por correo) ----------
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_RESPONSE_ADDRESS=
